rules_version = '2';

// Owner-only data model. Every collection must have an explicit match block —
// anything not matched below is denied by default.
//
// Keep the status whitelist in sync with the LessonStatus enum
// (lib/features/learn/model/lesson_progress.dart).
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUserDocument(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    // Gamification stats are optional fields but must be sane when present.
    function validStats(data) {
      return (!('xp' in data) || (data.xp is int && data.xp >= 0))
        && (!('streakCount' in data) || (data.streakCount is int && data.streakCount >= 0))
        && (!('lastActivityDate' in data) || data.lastActivityDate is string);
    }

    match /users/{userId} {
      // The profile document's id field must always mirror the auth uid.
      allow create, update: if ownsUserDocument(userId)
        && request.resource.data.id == userId
        && validStats(request.resource.data);
      allow read, delete: if ownsUserDocument(userId);

      // Per-lesson progress: users/{uid}/progress/{lessonId}.
      // The document id must equal the lessonId field, and status must be a
      // known enum value.
      match /progress/{lessonId} {
        allow create, update: if ownsUserDocument(userId)
          && request.resource.data.lessonId == lessonId
          && request.resource.data.status in ['notStarted', 'inProgress', 'completed'];
        allow read, delete: if ownsUserDocument(userId);
      }

      // Completed workout sessions: users/{uid}/sessions/{date}_{workoutId}.
      // The deterministic doc id caps XP at one award per workout per day.
      match /sessions/{sessionId} {
        allow create, update: if ownsUserDocument(userId)
          && request.resource.data.workoutId is string
          && request.resource.data.date is string
          && sessionId == request.resource.data.date + '_' + request.resource.data.workoutId;
        allow read, delete: if ownsUserDocument(userId);
      }
    }
  }
}
